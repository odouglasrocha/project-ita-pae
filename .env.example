# Copie para .env e preencha com suas credenciais reais.
# NUNCA faça commit do arquivo .env com valores reais.

# --- Supabase (projeto "pae") ---
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon-key...
# Somente para uso em backend/edge functions. Não exponha no cliente em produção.
VITE_SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key...
VITE_SUPABASE_ALLOW_INSECURE_TLS=true
SUPABASE_JWT_SECRET=seu-jwt-secret
